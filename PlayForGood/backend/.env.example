# PlayForGood backend environment template
# Copy this file to backend/.env and replace placeholder values.
# Do not commit real secrets.

# ---- Server URLs ----
PORT=4000
FRONTEND_URL=http://localhost:5173
# Optional comma-separated allow-list for additional frontend origins.
# Supports wildcard patterns, for example: https://playforgood.vercel.app,https://*.vercel.app
FRONTEND_URLS=
APP_URL=http://localhost:4000

# ---- Supabase (Dashboard -> Project Settings -> API) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional: Only for automated remote schema apply script (npm run db:apply:remote).
# Generate at https://supabase.com/dashboard/account/tokens
# Must be a Personal Access Token (starts with sbp_), not anon/service-role JWT keys.
SUPABASE_MANAGEMENT_TOKEN=sbp_xxx

# ---- Razorpay Test Mode (Dashboard -> API Keys / Subscriptions / Webhooks) ----
# Set to true only when Razorpay keys and plan IDs are configured.
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Signing secret from Razorpay webhook configuration
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
# Plan IDs for INR 499 monthly and INR 4999 yearly plans
RAZORPAY_MONTHLY_PLAN_ID=plan_xxx
RAZORPAY_YEARLY_PLAN_ID=plan_xxx

# ---- Resend (Dashboard -> API Keys) ----
RESEND_API_KEY=re_xxx
# Must be a verified sender in Resend.
# If you do not own a domain yet, verify a single sender email (for example yourname@gmail.com).
EMAIL_FROM=your_verified_sender@example.com

# ---- Business Rules ----
APP_CURRENCY=INR
APP_PRIZE_POOL_PERCENT=60
APP_MIN_CHARITY_PERCENT=10
